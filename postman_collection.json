{
  "info": {
    "name": "Finance Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Viewer\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) pm.collectionVariables.set('token', res.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@finance.local\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Analyst)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"analyst@finance.local\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login (Viewer)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"viewer@finance.local\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Users (Admin only)",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/REPLACE_WITH_USER_ID",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Analyst\",\n  \"email\": \"newanalyst@finance.local\",\n  \"password\": \"password123\",\n  \"role\": \"ANALYST\"\n}"
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/REPLACE_WITH_USER_ID",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"ANALYST\"\n}"
            }
          }
        },
        {
          "name": "Update User Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/REPLACE_WITH_USER_ID/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"INACTIVE\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Records",
      "item": [
        {
          "name": "List Records",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/records?page=1&limit=10&type=INCOME&sortBy=date&order=desc",
              "host": ["{{baseUrl}}"],
              "path": ["records"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "type", "value": "INCOME" },
                { "key": "sortBy", "value": "date" },
                { "key": "order", "value": "desc" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "List Records with Advanced Filters (Analyst/Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/records?minAmount=5000&maxAmount=100000&category=Salary&sortBy=amount&order=desc",
              "host": ["{{baseUrl}}"],
              "path": ["records"],
              "query": [
                { "key": "minAmount", "value": "5000" },
                { "key": "maxAmount", "value": "100000" },
                { "key": "category", "value": "Salary" },
                { "key": "sortBy", "value": "amount" },
                { "key": "order", "value": "desc" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Record by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/records/REPLACE_WITH_RECORD_ID",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Record (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/records",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50000,\n  \"type\": \"INCOME\",\n  \"category\": \"Salary\",\n  \"date\": \"2024-07-01\",\n  \"note\": \"July salary\"\n}"
            }
          }
        },
        {
          "name": "Update Record (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/records/REPLACE_WITH_RECORD_ID",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Updated note\",\n  \"amount\": 52000\n}"
            }
          }
        },
        {
          "name": "Soft Delete Record (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/records/REPLACE_WITH_RECORD_ID",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Summary (All roles)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/summary",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Category Breakdown (Analyst/Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/category-breakdown",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Monthly Trends (Analyst/Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/monthly-trends?year=2024",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Recent Activity (Analyst/Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/recent-activity?limit=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
